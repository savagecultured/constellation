# ==========================================
# Python & FastAPI standard ignores
# ==========================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ==========================================
# Virtual Environments
# ==========================================
# Ignored so you don't commit thousands of dependency files
venv/
env/
.venv/
.env_venv/
env.bak/
venv.bak/

# ==========================================
# Environment Variables & Secrets (CRITICAL)
# ==========================================
# Never commit your secrets, API keys, or local database URLs
.env
.env.*
!.env.example # It's good practice to commit a template file

# ==========================================
# Databases
# ==========================================
# Ignore local SQLite databases often used in dev
*.sqlite3
*.db

# ==========================================
# Testing & Coverage
# ==========================================
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
nosetests.xml

# ==========================================
# Type Checking (MyPy/Pyright)
# ==========================================
.mypy_cache/
.pyre/
.pytype/

# ==========================================
# IDEs & Editors
# ==========================================
# VS Code
.vscode/
*.code-workspace

# PyCharm / IntelliJ
.idea/

# Vim / Emacs
*.swp
*.swo
*~

# ==========================================
# OS Generated Files
# ==========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db